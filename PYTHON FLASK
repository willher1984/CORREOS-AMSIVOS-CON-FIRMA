@app.route("/guardar_firma/<cedula>", methods=["POST"])
def guardar_firma(cedula):

    datos = request.json["imagen"]

    imagen = datos.split(",")[1]

    archivo = base64.b64decode(imagen)

    firma_path = f"firmas/{cedula}.png"

    with open(firma_path, "wb") as f:
        f.write(archivo)

    insertar_firma_pdf(cedula)

    try:
        registrar_en_sheets(cedula)
    except Exception as e:
        print("Error Sheets:", e)

    return "PDF firmado correctamente"

# =========================
# INSERTAR FIRMA EN PDF
# =========================
def insertar_firma_pdf(cedula):

    archivos = glob.glob(f"pdfs/{cedula}*.pdf")

    if not archivos:
        raise FileNotFoundError(
            f"No existe PDF para la cédula {cedula}"
        )

    pdf_original = archivos[0]

    pdf_final = f"G:/Mi unidad/PDF_FIRMADOS/{cedula}_firmado.pdf"

    packet = io.BytesIO()

    can = canvas.Canvas(
        packet,
        pagesize=letter
    )

    firma = ImageReader(
        f"firmas/{cedula}.png"
    )

    can.drawImage(
        firma,
        300,
        250,
        width=180,
        height=60,
        mask="auto"
    )

    can.save()

    packet.seek(0)

    nuevo_pdf = PdfReader(packet)

    with open(pdf_original, "rb") as archivo_pdf:

        pdf_existente = PdfReader(archivo_pdf)

        salida = PdfWriter()

        pagina = pdf_existente.pages[0]

        pagina.merge_page(
            nuevo_pdf.pages[0]
        )

        salida.add_page(pagina)

        with open(pdf_final, "wb") as salida_pdf:
            salida.write(salida_pdf)
def registrar_en_sheets(cedula):

    fila = df[df["cedula"] == int(cedula)]

    if fila.empty:
        return

    nombre = fila.iloc[0]["nombre"]
    correo = fila.iloc[0]["correo"]

    data = {
        "cedula": str(cedula),
        "nombre": str(nombre),
        "correo": str(correo),
        "fecha": datetime.now().strftime("%d/%m/%Y"),
        "hora": datetime.now().strftime("%H:%M")
    }

    try:
        requests.post(GOOGLE_SHEETS_URL, json=data)
        print("Registrado en Sheets")
    except Exception as e:
        print("Error Sheets:", e)
