@app.route("/enviar_todos")
def enviar_todos():

    total = len(df)

    enviados = 0

    for _, fila in df.iterrows():

        cedula = str(fila["cedula"])

        try:

            enviar_correo(cedula)

            enviados += 1

            print(f"Enviado {enviados} de {total} -> {cedula}")

            time.sleep(10)

        except Exception as e:

            print(f"Error con {cedula}: {e}")

    return f"Proceso terminado. Enviados: {enviados}"

