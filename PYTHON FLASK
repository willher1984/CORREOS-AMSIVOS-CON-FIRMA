    if not correo:
        print("No se encontró correo")
        return

    link = f"https://condiment-transpose-explicit.ngrok-free.dev/firma/{cedula}"

    mensaje = MIMEMultipart()

    mensaje["Subject"] = "Cuenta de cobro transporte Consorcio BFTEL"
    mensaje["From"] = "transportebftel@gmail.com"
    mensaje["To"] = correo

